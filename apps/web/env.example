# Web App Environment Variables
# Copy this file to .env.local and update with your values

# API Configuration
# For development: http://localhost:3001/api
# For production (Vercel): https://api.agora-citoyens.fr/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Base URL for the web app (used by sitemap.xml, robots.txt, and embed snippets).
# For production (Vercel): https://agora-citoyens.fr
# NEXT_PUBLIC_APP_URL=https://agora-citoyens.fr
